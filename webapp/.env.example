# Supabase — claves públicas (también necesarias en Vercel como variables de entorno)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_SUPABASE_PROJECT_ID=YOUR-PROJECT-ID

# (Opcional) URL de redirect para autenticación. En Vercel, configura
# NEXT_PUBLIC_SITE_URL con el dominio de producción para evitar enlaces a localhost.
# NEXT_PUBLIC_SITE_URL=https://tu-dominio.vercel.app
